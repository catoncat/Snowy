{
  "manifest_version": 3,
  "name": "Browser Brain Loop Next",
  "version": "0.0.1",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "BBL Next"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/page-hook.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}

