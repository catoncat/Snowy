{
  "manifest_version": 3,
  "name": "Browser Brain Loop Next",
  "version": "0.0.1",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "offscreen"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "BBL Next"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  }
}
