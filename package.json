{
  "name": "browser-brain-loop-next",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run test",
    "workflow:claim": "bun .agents/skills/auto-claim-issues-next/scripts/claim-issue.ts --assignee=agent",
    "workflow:claim:preview": "bun .agents/skills/auto-claim-issues-next/scripts/claim-issue.ts --dry-run --assignee=agent",
    "workflow:claim:json": "bun .agents/skills/auto-claim-issues-next/scripts/claim-issue.ts --json --assignee=agent",
    "workflow:plan": "bun .agents/skills/next-batch-planner/scripts/plan-next-batch.ts",
    "workflow:plan:preview": "bun .agents/skills/next-batch-planner/scripts/plan-next-batch.ts --dry-run",
    "workflow:plan:json": "bun .agents/skills/next-batch-planner/scripts/plan-next-batch.ts --json",
    "workflow:new-review-issue": "bun .agents/skills/next-batch-planner/scripts/create-review-issue.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "fake-indexeddb": "^6.2.4",
    "idb": "^8.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
