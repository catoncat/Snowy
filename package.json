{
  "name": "browser-brain-loop-next",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "bun ext:dev",
    "build": "bun ext:build",
    "text": "bun ext:text",
    "ext:dev": "cd apps/mv3-shell && bun run dev",
    "ext:build": "cd apps/mv3-shell && bun run build",
    "ext:test": "bun run test -- apps/mv3-shell/test/manifest.spec.ts",
    "typecheck:mv3-bridge": "vitest run apps/mv3-shell/test/manifest.spec.ts --testNamePattern='mv3 gate:'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && bun run typecheck:mv3-bridge",
    "check": "bun run typecheck && bun run lint && bun run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "release:acceptance": "bun scripts/release-acceptance.ts",
    "release:cutover:status": "bun scripts/release-cutover-status.ts",
    "release:package:mv3": "bun scripts/release-package-mv3.ts",
    "release:smoke:mv3": "bun scripts/release-smoke-mv3-real-browser.ts",
    "release:uat:real-profile": "bun scripts/release-uat-real-profile.ts",
    "workflow:claim": "bun .agents/skills/auto-claim-issues-next/scripts/claim-issue.ts",
    "workflow:claim:preview": "bun .agents/skills/auto-claim-issues-next/scripts/claim-issue.ts --dry-run",
    "workflow:claim:json": "bun .agents/skills/auto-claim-issues-next/scripts/claim-issue.ts --json",
    "workflow:done": "bun .agents/skills/auto-claim-issues-next/scripts/complete-issue.ts",
    "workflow:done:json": "bun .agents/skills/auto-claim-issues-next/scripts/complete-issue.ts --json",
    "workflow:queue:build": "bun .agents/skills/auto-claim-issues-next/scripts/build-live-queue.ts",
    "workflow:queue:preview": "bun .agents/skills/auto-claim-issues-next/scripts/build-live-queue.ts --dry-run",
    "workflow:queue:json": "bun .agents/skills/auto-claim-issues-next/scripts/build-live-queue.ts --json",
    "workflow:plan": "bun .agents/skills/next-batch-planner/scripts/plan-next-batch.ts",
    "workflow:plan:preview": "bun .agents/skills/next-batch-planner/scripts/plan-next-batch.ts --dry-run",
    "workflow:plan:json": "bun .agents/skills/next-batch-planner/scripts/plan-next-batch.ts --json",
    "workflow:new-review-issue": "bun .agents/skills/next-batch-planner/scripts/create-review-issue.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^24.0.0",
    "fake-indexeddb": "^6.2.4",
    "idb": "^8.0.3",
    "playwright": "^1.60.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
